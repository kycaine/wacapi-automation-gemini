# ============================================================
# WA Automation SaaS - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- App ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- JWT ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRES_IN=7d

# --- Encryption ---
# 32-byte hex key for AES-256 encryption of WhatsApp access tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wacapi
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Google Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
# Max tokens to send in conversation history to Gemini
GEMINI_MAX_HISTORY_TOKENS=8000
# Max output tokens per response
GEMINI_MAX_OUTPUT_TOKENS=1024

# --- WhatsApp / Meta ---
# Your Meta App Secret (for webhook signature verification)
META_APP_SECRET=your_meta_app_secret_here
# Webhook verification token (you define this in Meta Developer Console)
WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_here
# Meta Graph API version
META_API_VERSION=v19.0

# --- Rate Limiting ---
# Max requests per time window per IP
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# --- Usage Limits (per client per month) ---
DEFAULT_MONTHLY_MESSAGE_LIMIT=10000
DEFAULT_MONTHLY_TOKEN_LIMIT=5000000

# --- Queue ---
QUEUE_NAME=message-queue
QUEUE_CONCURRENCY=5
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_DELAY_MS=5000
